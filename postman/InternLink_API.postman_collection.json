            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"test1234\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer YOUR_TOKEN_HERE" }
            ],
            "url": { "raw": "http://127.0.0.1:8000/api/logout/", "host": ["127.0.0.1"], "port": "8000", "path": ["api", "logout", ""] },
            "body": { "mode": "raw", "raw": "" }
          }
        }
      ]
